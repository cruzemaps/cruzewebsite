{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cruzewebsite",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
